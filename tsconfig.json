{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      //server
      "@server/validators/*": ["./server/validators/*"],
      "@server/models/*": ["./server/models/*"],
      "@server/utils/*": ["./server/utils/*"],
      "@server/guard/*":["./server/guard/*"],
      "@server/schemas/*":["./server/schemas/*"],
      //client
      "@components/*": ["./src/components/*"],
      "@components/form/*": ["./src/components/form/*"],
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts"
  ],
  "exclude": ["node_modules"]
}
